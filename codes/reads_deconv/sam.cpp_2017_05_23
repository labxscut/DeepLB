ReadPair::ReadPair(ReadProcessed & r_forward, ReadProcessed & r_reverse, const int min_cpg_sites_) {
	read_forward = & r_forward;
	read_reverse = & r_reverse;
	fragment_name = read_forward->get_read_name();
	tag_RG = read_forward->get_tag_RG();
	min_cpg_sites = min_cpg_sites_;
	check_valid_cpg_sites();
	remove_overlap_of_two_reads();
	if ( get_num_valid_cpg_sites() >= min_cpg_sites )
		valid = true;
	else
		valid = false;
}

//
// Forward read info: marker1_index_forward, marker2_index_forward, boundary_forward
// Revese read info : marker1_index_reverse, marker2_index_reverse, boundary_reverse
//
// marker1_index and marker2_index have six cases:
//   (1) 0 and -1       : reads completely fall into marker1, which is invalid (i.e., complementary bin). All CpG sites in the read are invalide.
//   (2) non-zero and -1: reads completely fall into marker1, which is valid. All CpG sites are valid.
//   (3) 0 and 0        : reads cover two markers, but all two markers are invalid (i.e., complementary bins). All CpG sites in the read are invalid.
//   (4) non-zero and 0 : reads cover two markers. marker1 is valid and marker2 is invalid. Only CpG sites falling into marker1 are valid.
//   (5) 0 and non-zero : reads cover two markers. marker1 is invalid and marker2 is valid. Only CpG sites falling into marker2 are valid.
//   (6) non-zero and non-zero: reads cover two markers, both are valid. All CpG sites in the read are valid.
//
// boundary: it is the boundary position of two adjacent marker bins. marker1: [a, boundary) and marker2: [boundary,b)
//
// return value: how_to_process_read_pair
//	-1: discard both reads
//	0: process only forward read
//	1: process only reverse read
//	2: process both reads
//
void ReadPair::check_valid_cpg_sites()
{
	if (read_forward->is_within_markers()) {
		if ( ! read_forward->is_cpg_sites_valid_checked() ) {
			read_forward->check_valid_cpg_sites(); // fill member variables of read_forward: valid_cpg_sites, valid_methylation_status
		}
	}
	if (read_reverse->is_within_markers()) {
		if ( ! read_reverse->is_cpg_sites_valid_checked() ) {
			read_reverse->check_valid_cpg_sites(); // fill member variables of read_reverse: valid_cpg_sites, valid_methylation_status
		}
	}
}

//
// This function refers to equivalent codes of two functions:
// remove_if, see details at http://www.cplusplus.com/reference/algorithm/remove_if/
// set_intersection, see details at http://www.cplusplus.com/reference/algorithm/set_intersection/
//
// the overlapped cpg sites in the reverse read are removed
//
// read 1 1 is forward read, read 2 is reverse read
//
void remove_overlap_from_second_read_v2(vector<GENOME_POSITION> & r1, string & r1_str,
	vector<GENOME_POSITION> & r2, string & r2_str)
{
	vector<GENOME_POSITION>::iterator first1 = r1.begin();
	string::iterator first1_str = r1_str.begin();

	vector<GENOME_POSITION>::iterator last1_new = r1.begin();
	string::iterator last1_str_new = r1_str.begin();

	vector<GENOME_POSITION>::iterator first2 = r2.begin();
	string::iterator first2_str = r2_str.begin();

	vector<GENOME_POSITION>::iterator last2_new = r2.begin();
	string::iterator last2_str_new = r2_str.begin();

	while (first2!=r2.end()) {
		if (first1==r1.end()) {
			// keep the rest of read 2, when finishing the scanning of read 1
			*last2_new=*first2; *last2_str_new=*first2_str;
			++last2_new; ++last2_str_new;
			++first2; ++first2_str;
		} else {
			if (*first1<*first2) {
				// cpg site is not the same, so we keep this cpg site for read 1
				*last1_new = *first1; *last1_str_new = *first1_str;
				++last1_new; ++last1_str_new;
				++first1; ++first1_str;
			} else if (*first2<*first1) {
				// cpg site is not the same, so we keep this cpg site for read 2
				*last2_new=*first2; *last2_str_new=*first2_str;
				++last2_new; ++last2_str_new;
				++first2; ++first2_str;
			} else {
				// overlapping cpg sites of two reads
				// check if their methylation status of two reads are the same or not.
				if (*first1_str == *first2_str) {
					// keep this cpg site for read 1, because the methylation status of this shared cpg site is the same
#ifdef DEBUG
					cerr << *first1 << "\t" << *first1_str << endl << flush;
#endif
					*last1_new = *first1; *last1_str_new = *first1_str;
					++last1_new; ++last1_str_new;
				}
				// then remove these overlaps from the reverse read
				++first1; ++first1_str;
				++first2; ++first2_str;
			}
		}
	}
	while (first1!=r1.end()) {
		*last1_new=*first1; *last1_str_new=*first1_str;
		++last1_new; ++last1_str_new;
		++first1; ++first1_str;
	}
	r1.erase(last1_new, r1.end());
	r1_str.erase(last1_str_new, r1_str.end());
	r2.erase(last2_new, r2.end());
	r2_str.erase(last2_str_new, r2_str.end());
#ifdef DEBUG
	cerr << "*** in remove_overlap(), r: " << r1.size() << "\t" << r2.size() << endl;
	cerr << "*** in remove_overlap(), r_str: " << r1_str.size() << "\t" << r2_str.size() << endl;
#endif
}

void ReadPair::remove_overlap_of_two_reads() {
	int marker_of_forward_read = read_forward->get_marker_of_read_reside_in();
	int marker_of_reverse_read = read_reverse->get_marker_of_read_reside_in();
	if ( (marker_of_forward_read==marker_of_reverse_read) && (marker_of_forward_read>0) ) { // both reads fall into the same marker
		vector<GENOME_POSITION> & r1_cpg_sites = read_forward->get_valid_cpg_sites();
		string &  r1_meth_status = read_forward->get_valid_methylation_status();
		vector<GENOME_POSITION> & r2_cpg_sites = read_reverse->get_valid_cpg_sites();
		string &  r2_meth_status = read_reverse->get_valid_methylation_status();
		if (r1_cpg_sites.size()>0 && r2_cpg_sites.size()>0) {
			// modify the reverse read by removing the overlap
#ifdef DEBUG
			cerr << "************* before test remove overlap **************" << endl;
			cerr << "read 1 (valid): " << read_forward->str_of_valid_cpg_sites() << endl;
			cerr << "read 2 (valid): " << read_reverse->str_of_valid_cpg_sites() << endl;
			cerr << "read 1: " << read_forward->str_of_cpg_sites() << endl;
			cerr << "read 2: " << read_reverse->str_of_cpg_sites() << endl << flush;
			cerr << "*********************************" << endl;
#endif
			remove_overlap_from_second_read_v2(r1_cpg_sites, r1_meth_status, r2_cpg_sites, r2_meth_status);
#ifdef DEBUG
			cerr << "************* done test remove overlap **************" << endl;
			cerr << "read 1 (valid): " << read_forward->str_of_valid_cpg_sites() << endl;
			cerr << "read 2 (valid): " << read_reverse->str_of_valid_cpg_sites() << endl;
			cerr << "read 1: " << read_forward->str_of_cpg_sites() << endl;
			cerr << "read 2: " << read_reverse->str_of_cpg_sites() << endl;
			cerr << "*********************************" << endl << flush;
#endif
		}
	}
}

//
// print header to stdout:
//
//   0: print nothing
//
//   1: print one or two lines the compact version (used for calculating read likelihood) for only valid CpG sites of the read pair, which fall into the marker bin. If two reads of a fragment falls into different markers, then print two reads of a fragment in two lines. Format is below:
// marker1_index   marker2_index   chr start_pos   end_pos strand  num_CpG_sites   CpG_sites   sites_methylation_status	read_name	RG
//		marker1_index   marker2_index: the marker that the fragment falls into
//		bad:	0	0
//		bad:	0	-1
//		good:	0	9(non-zero)
//		good:	non-zero	0
//		good:	non-zero  -1
//		good:	non-zero  non-zero
//
//		strand
//		+:	a single forward read
//		-:	a single reverse read
//		+-:	read pair of the whole fragment
//
//		read_name: the 1st column of the SAM file
//
//   2: print into one line the full version (used for checking) of only valid CpG sites of the read pair, which fall into the marker bin. Format is below:
// f_read_marker1_index f_read_marker2_index f_read_chr f_read_start_pos f_read_end_pos f_read_num_CpG_sites f_read_CpG_sites f_read_sites_methylation_status r_read_marker1_index r_read_marker2_index r_read_chr r_read_start_pos r_read_end_pos r_read_num_CpG_sites r_read_CpG_sites r_read_sites_methylation_status fragment_name RG
//
//   3: print into one line the full version (used for checking) of all CpG sites of the read pair
//
//   11: based on print_level=1, print one additional column "endpos_of_read1,startpos_of_read2", right before "read_name"
//
void ReadPair::print_header(const int print_level, const bool print_tag_RG)
{
	if (print_level==1) {
		cout << "marker1_index" << "\t" << "marker2_index" << "\t" << "chr" << "\t" << "start_pos" << "\t" << "end_pos" << "\t" << "strand" << "\t" << "num_CpG_sites" << "\t" << "CpG_sites" << "\t" << "sites_methylation_status" << "\t" << "read_name";
	}
	if (print_level==2 || print_level==3) {
		cout << "f_read_marker1_index" << "\t" << "f_read_marker2_index" << "\t" << "f_read_chr" << "\t" << "f_read_start_pos" << "\t" << "f_read_end_pos" << "\t" << "f_read_num_CpG_sites" << "\t" << "f_read_CpG_sites" << "\t" << "f_read_sites_methylation_status" << "\t" << "r_read_marker1_index" << "\t" << "r_read_marker2_index" << "\t" << "r_read_chr" << "\t" << "r_read_start_pos" << "\t" << "r_read_end_pos" << "\t" << "r_read_num_CpG_sites" << "\t" << "r_read_CpG_sites" << "\t" << "r_read_sites_methylation_status" << "\t" << "fragment_name";
	}
	if (print_level==11) {
		cout << "marker1_index" << "\t" << "marker2_index" << "\t" << "chr" << "\t" << "start_pos" << "\t" << "end_pos" << "\t" << "strand" << "\t" << "num_CpG_sites" << "\t" << "CpG_sites" << "\t" << "sites_methylation_status" << "\t" << "endpos_of_read1,startpos_of_read2" << "\t" << "read_name";
	}
	if (print_tag_RG) cout << "\t" << "RG";
	cout << endl;
}

void ReadPair::print(const int print_level, const bool print_tag_RG) {
	if (is_valid()) {
		if (print_level==1) { // print into one or two lines the compact format, only for calculating fragment likelihood
			if (read_forward->is_within_markers() && !read_reverse->is_within_markers()) {
				// only forward read falls into the marker. output it to a line.
				read_forward->print(1, print_tag_RG);
			}
			if (!read_forward->is_within_markers() && read_reverse->is_within_markers()) {
				// only reverse read falls into the marker. output it to a line.
				read_reverse->print(1, print_tag_RG);
			}
			if (read_forward->is_within_markers() && read_reverse->is_within_markers()) {
				// both forward read and reverse read fall into markers. output it to a line.
				int marker_of_forward_read = read_forward->get_marker_of_read_reside_in();
				int marker_of_reverse_read = read_reverse->get_marker_of_read_reside_in();
				if ( marker_of_forward_read == marker_of_reverse_read ) { // both reads fall into the same marker
					cout << marker_of_forward_read << "\t" << "-" << "\t" << read_forward->get_chr() << "\t" << read_forward->get_start_pos() << "\t" << read_reverse->get_end_pos() << "\t" << "+-" << "\t" << read_forward->get_num_valid_cpg_sites()+read_reverse->get_num_valid_cpg_sites() << "\t";
					if (read_forward->get_num_valid_cpg_sites()==0) {
						cout << read_reverse->str_of_valid_cpg_sites();
					}
					if (read_reverse->get_num_valid_cpg_sites()==0) {
						cout << read_forward->str_of_valid_cpg_sites();
					}
					if (read_forward->get_num_valid_cpg_sites()>0 && read_reverse->get_num_valid_cpg_sites()>0)
						cout << read_forward->str_of_valid_cpg_sites() << "," << read_reverse->str_of_valid_cpg_sites();
					cout << "\t" << read_forward->get_valid_methylation_status() << read_reverse->get_valid_methylation_status() << "\t" << fragment_name;
					if (print_tag_RG) cout << "\t" << get_tag_RG();
					cout << endl;
				} else {
					// both reads fall into different markers. output them in two lines
					read_forward->print(1, print_tag_RG);
					read_reverse->print(1, print_tag_RG);
				}
			}
		}
		if (print_level==11) { // print into one or two lines the compact format, only for calculating fragment likelihood
			if (read_forward->is_within_markers() && !read_reverse->is_within_markers()) {
				// only forward read falls into the marker. output it to a line.
				read_forward->print(11, print_tag_RG);
			}
			if (!read_forward->is_within_markers() && read_reverse->is_within_markers()) {
				// only reverse read falls into the marker. output it to a line.
				read_reverse->print(11, print_tag_RG);
			}
			if (read_forward->is_within_markers() && read_reverse->is_within_markers()) {
				// both forward read and reverse read fall into markers. output it to a line.
				int marker_of_forward_read = read_forward->get_marker_of_read_reside_in();
				int marker_of_reverse_read = read_reverse->get_marker_of_read_reside_in();
				if ( marker_of_forward_read == marker_of_reverse_read ) { // both reads fall into the same marker
					cout << marker_of_forward_read << "\t" << "-" << "\t" << read_forward->get_chr() << "\t" << read_forward->get_start_pos() << "\t" << read_reverse->get_end_pos() << "\t" << "+-" << "\t" << read_forward->get_num_valid_cpg_sites()+read_reverse->get_num_valid_cpg_sites() << "\t";
					if (read_forward->get_num_valid_cpg_sites()==0) {
						cout << read_reverse->str_of_valid_cpg_sites();
					}
					if (read_reverse->get_num_valid_cpg_sites()==0) {
						cout << read_forward->str_of_valid_cpg_sites();
					}
					if (read_forward->get_num_valid_cpg_sites()>0 && read_reverse->get_num_valid_cpg_sites()>0)
						cout << read_forward->str_of_valid_cpg_sites() << "," << read_reverse->str_of_valid_cpg_sites();
					cout << "\t" << read_forward->get_valid_methylation_status() << read_reverse->get_valid_methylation_status() << "\t" << read_forward->get_end_pos() << "," << read_reverse->get_start_pos() << "\t" << fragment_name;
					if (print_tag_RG) cout << "\t" << get_tag_RG();
					cout << endl;
				} else {
					// both reads fall into different markers. output them in two lines
					read_forward->print(11, print_tag_RG);
					read_reverse->print(11, print_tag_RG);
				}
			}
		}
		if (print_level==2 ) { // print into one line the full version (used for checking) of only valid CpG sites of the read pair, which fall into the marker bin.
			cout << read_forward->str_of_read_position() << "\t" << read_forward->get_num_valid_cpg_sites() << "\t" << read_forward->str_of_valid_cpg_sites() << "\t" << read_forward->get_valid_methylation_status() << "\t";
			cout << read_reverse->str_of_read_position() << "\t" << read_reverse->get_num_valid_cpg_sites() << "\t" << read_reverse->str_of_valid_cpg_sites() << "\t" << read_reverse->get_valid_methylation_status() << "\t" << fragment_name;
			if (print_tag_RG) cout << "\t" << get_tag_RG();
			cout << endl;
		}
		if (print_level==3 ) { // print into one line the full version (used for checking) of all CpG sites of the read pair.
			cout << read_forward->str_of_read_position() << "\t" << read_forward->get_num_cpg_sites() << "\t" << read_forward->str_of_cpg_sites() << "\t" << read_forward->get_methylation_status() << "\t";
			cout << read_reverse->str_of_read_position() << "\t" << read_reverse->get_num_cpg_sites() << "\t" << read_reverse->str_of_cpg_sites() << "\t" << read_reverse->get_methylation_status() << "\t" << fragment_name;
			if (print_tag_RG) cout << "\t" << get_tag_RG();
			cout << endl;
		}
	}
}

void ReadPair::methycount_bins( Bins2Values & bins2methycount )
{
	if (is_valid()) {
		if (read_forward->is_within_markers())
			read_forward->methycount_bins( bins2methycount );
		if (read_reverse->is_within_markers())
			read_reverse->methycount_bins( bins2methycount );
		int marker_of_forward_read = read_forward->get_marker_of_read_reside_in();
		int marker_of_reverse_read = read_reverse->get_marker_of_read_reside_in();
		if (read_forward->is_within_markers() && !read_reverse->is_within_markers()) {
			bins2methycount[marker_of_forward_read][3]++; // count this forward read as a fragment in this bin
		}
		if (!read_forward->is_within_markers() && read_reverse->is_within_markers()) {
			bins2methycount[marker_of_reverse_read][3]++; // count this reverse read as a fragment in this bin
		}
		if (read_forward->is_within_markers() && read_reverse->is_within_markers()) {
			if ( marker_of_forward_read == marker_of_reverse_read ) { // both reads fall into the same marker, so count them as a fragment
				bins2methycount[marker_of_forward_read][3]++;
			} else { // both reads fall into different markers, so count two reads as two different fragments that fall into different markers
				if (read_forward->get_num_valid_cpg_sites()>0)
					bins2methycount[marker_of_forward_read][3]++;
				if (read_reverse->get_num_valid_cpg_sites()>0)
					bins2methycount[marker_of_reverse_read][3]++;
			}
		}
	}
}

