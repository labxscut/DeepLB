// print_flag (print to stdout):
//   0: print nothing
//   1: print only valid CpG sites of this read, which fall into the marker bin.
//   2: print all CpG sites of this read
//
// bins2methycount: each bin is associated with a vector of three value; Input is initialized as zeros.
//   (1) the number of methylation count in this bin.
//   (2) the number of unmethylation count in this bin.
//   (3) the number of reads in this bin.
//
// For paired-end reads of sam file
//
void binning_paired_end_reads_of_sam_file_with_bins_methycounts(
	string sam_file, Bins_end_coord & bins_end_coord,
	Bins_index & bins_index, int min_cpg_sites,
	int print_level, bool print_tag_RG, Bins2Values & bins2methycount)
{
	cerr << "reading '" << sam_file << "'" << endl;
	istream * in=&cin; // default is stdin
	ifstream fin;
	if ( !(sam_file.compare("stdin")==0) ) {
		fin.open(sam_file.c_str());
		if (fin.fail()){
			cerr << "Error: Unable to read " << sam_file << " in binning_paired_end_reads_of_sam_file_with_bins_methycounts()" << endl;
			exit(EXIT_FAILURE);
		}
		in = &fin;
	}
	char line[MAX_LINE_CHAR];
	unsigned long i_line=0;
	unsigned long out_line=0;
	HISTORY_READS que_forward_reads;
	QUEUE_READS_NAME que_forward_reads_names;
	while(!(*in).getline(line, MAX_LINE_CHAR).eof()) {
		//process the input line
		string line_(line);
		Sam rawread(line_);
		string & read_name = rawread.reference_id();
		bool is_paired = rawread.is_paired();
		bool is_reverse = rawread.is_reverse();
		ReadProcessed* read = new ReadProcessed(rawread, bins_end_coord, bins_index, min_cpg_sites);
#ifdef DEBUG
		cerr << endl << "-------- read " << i_line+1 << " --------" << endl;
		cerr << line_ << endl;
		cerr << "paired: " << is_paired << endl;
		if (is_reverse)
			cerr << "strand: -" << endl;
		else
			cerr << "strand: +" << endl;
		cerr << "read (valid):" << "\t" << read->str_of_valid_cpg_sites() << endl;
		cerr << "read :" << "\t" << read->str_of_cpg_sites() << endl;
		cerr << flush;
#endif
		if ( !is_paired ) {
			// a single-end read
			if ( read->is_valid() ) {
				out_line++;
				if (out_line==1) read->print_header( print_level, print_tag_RG );
				read->print( print_level, print_tag_RG );
				read->methycount_bins( bins2methycount );
				int marker_of_read = read->get_marker_of_read_reside_in();
				bins2methycount[marker_of_read][3]++; // count this forward read as a fragment in this bin
			}
			delete read;
		} else {
			// a paired-end (PE) read
			// find its paired read in the other strand, then get the fragment of this read pair
			// In a sorted sam file, usually the read in the forward (+) strand should occurs before the read in the reverse (-) strand.
			if ( !is_reverse ) {
				// a forward PE read
				// If it does not fall into a marker region, delete it; otherwise deposit it to the queue (without checking its valid cpg site number) and will be processed (1) when encountering its paired backward read later; and (2) when this forward read becomes the front of the queue and the queue size exceeds the limit.
				if (!read->is_within_markers()) {
					delete read;
				} else {
#ifdef DEBUG
					cerr << "push forward read to queue, before" << endl;
					cerr << flush;
#endif
					que_forward_reads_names.push_back( read_name );
					que_forward_reads[read_name] = read;
#ifdef DEBUG
					cerr << "push forward read to queue, after" << endl;
					print_queue( cerr, que_forward_reads, que_forward_reads_names );
		cerr << "read (valid):" << "\t" << read->str_of_valid_cpg_sites() << endl;
		cerr << "read :" << "\t" << read->str_of_cpg_sites() << endl;
					cerr << flush;
#endif


					// check if the queue size exceeds the limit, if so, process, print and remove the read at the front of the queue
					if ( que_forward_reads_names.size() > NUM_HISTORY_READS_KEPT ) {
						// the read in the front of the queue indicates this is a forward read and still cannot find its paired backward read. So we need to process and output this read, then remove it from the queue to keep queue size not exceeding the limit.
						string & forward_history_read_name = que_forward_reads_names.front();
						ReadProcessed * forward_history_read = que_forward_reads[forward_history_read_name];
#ifdef DEBUG2
						cerr << "remove front read from queue, before: " << forward_history_read->str_of_read_strand() << forward_history_read_name << endl;
						cerr << flush;
#endif
						if ( forward_history_read->is_valid() ) {
#ifdef DEBUG2
							cerr << "\tprint front read of queue (that will be removed), before" << endl;
							cerr << flush;
							cerr << "Warning: " << forward_history_read_name << " (- strand) cannot be found in the sam file, so we print out the forward read!" << endl;
#endif
							out_line++;
							if (out_line==1) forward_history_read->print_header( print_level, print_tag_RG );
							forward_history_read->print( print_level, print_tag_RG );
							forward_history_read->methycount_bins( bins2methycount );
							int marker_of_read = forward_history_read->get_marker_of_read_reside_in();
							bins2methycount[marker_of_read][3]++; // count this forward read as a fragment in this bin
#ifdef DEBUG2
							cerr << "\tprint front read of queue (that will be removed), after" << endl;
							cerr << flush;
#endif
						} else {
#ifdef DEBUG2
							cerr << "\tfront read of queue (that will be removed), is not valid, cannot be print out: " << forward_history_read->str_of_read_strand() << forward_history_read_name << endl << flush;
#endif
						}
						// keep the queue size <= NUM_HISTORY_READS_KEPT, by removing the read in the front of the queue
						que_forward_reads.erase( forward_history_read_name );
						delete forward_history_read;
						que_forward_reads_names.pop_front();
#ifdef DEBUG
						cerr << "remove front read from queue, after" << endl;
						print_queue( cerr, que_forward_reads, que_forward_reads_names );
						cerr << flush;
#endif
					}


				}
			} else {
				// a reverse PE read
				// we get its matched forward PE read, then check the fragment that consists of two PE reads
				if ( que_forward_reads.find(read_name) == que_forward_reads.end() ) {
					// unable to find its matched forward PE read in the queue
					// output this read
#ifdef DEBUG3
					cerr << "Warning: " << read_name << " (- reverse strand) cannot find its matched forward read in the queue, so we print out this reverse read!" << endl;
#endif
					if ( read->is_valid() ) {
						out_line++;
						if (out_line==1) read->print_header( print_level, print_tag_RG );
						read->print( print_level, print_tag_RG );
						read->methycount_bins( bins2methycount );
						int marker_of_read = read->get_marker_of_read_reside_in();
						bins2methycount[marker_of_read][3]++; // count this reverse read as a fragment in this bin
#ifdef DEBUG
						cout << flush;
						cerr << flush;
#endif
					}
					delete read;
#ifdef DEBUG
					cerr << "delete unmatched reverse read, after" << endl;
					cerr << flush;
#endif
				} else {
					// this is a complete fragment (forward read + reverse read), we found its paired forward read in the history read queue.
					// retrieve its paired forward read in the history queue
					ReadProcessed * forward_matched_read = que_forward_reads[read_name];
#ifdef DEBUG
					cerr << "create fragment, before" << endl;
					cerr << "read 1 (valid):" << "\t" << forward_matched_read->get_num_valid_cpg_sites() << "\t" << forward_matched_read->str_of_valid_cpg_sites() << "\t" << forward_matched_read->get_valid_methylation_status() << endl;
					cerr << "read 1:" << "\t" << forward_matched_read->get_num_cpg_sites() << "\t" << forward_matched_read->str_of_cpg_sites() << "\t" << forward_matched_read->get_methylation_status() << endl;
					cerr << "read 2 (valid):" << "\t" << read->get_num_valid_cpg_sites() << "\t" << read->str_of_valid_cpg_sites() << "\t" << read->get_valid_methylation_status() << endl;
					cerr << "read 2:" << "\t" << read->get_num_cpg_sites() << "\t" << read->str_of_cpg_sites() << "\t" << read->get_methylation_status() << endl;
					cerr << flush;
#endif
					ReadPair fragment( *forward_matched_read, *read, min_cpg_sites );
#ifdef DEBUG
					cerr << "create fragment, done" << endl;
					ReadProcessed * r1 = fragment.get_forward_read();
					ReadProcessed * r2 = fragment.get_reverse_read();
					cerr << "read 1 (valid):" << "\t" << r1->get_num_valid_cpg_sites() << "\t" << r1->str_of_valid_cpg_sites() << "\t" << r1->get_valid_methylation_status() << endl;
					cerr << "read 1:" << "\t" << r1->get_num_cpg_sites() << "\t" << r1->str_of_cpg_sites() << "\t" << r1->get_methylation_status() << endl;
					cerr << "read 2 (valid):" << "\t" << r2->get_num_valid_cpg_sites() << "\t" << r2->str_of_valid_cpg_sites() << "\t" << r2->get_valid_methylation_status() << endl;
					cerr << "read 2:" << "\t" << r2->get_num_cpg_sites() << "\t" << r2->str_of_cpg_sites() << "\t" << r2->get_methylation_status() << endl;
					cerr << flush;
#endif
					if ( fragment.is_valid() ) {
#ifdef DEBUG
						cerr << "print fragment, before" << endl;
						cerr << flush;
#endif
						out_line++;
						if (out_line==1) fragment.print_header( print_level, print_tag_RG );
						fragment.print( print_level, print_tag_RG );
#ifdef DEBUG
						cerr << "print fragment, done" << endl;
						cerr << flush;
#endif
						fragment.methycount_bins( bins2methycount );
					}
					delete read;
					que_forward_reads.erase( read_name );
					delete forward_matched_read;
					QUEUE_READS_NAME::iterator it = std::find(que_forward_reads_names.begin(), que_forward_reads_names.end(), read_name);
					que_forward_reads_names.erase( it );
#ifdef DEBUG
					cerr << "remove matched forward read from queue, done" << endl;
					print_queue( cerr, que_forward_reads, que_forward_reads_names );
					cerr << flush;
#endif
				}
			}
		}
#ifdef DEBUG
		cerr << flush;
#endif
		i_line++;
	}
	// print all unmatched reads in queue
#ifdef DEBUG
	cerr << endl;
	cerr << "Clear all reads in the queue (#read=" << que_forward_reads_names.size() << ", " << que_forward_reads.size() << ")" << endl;
	print_queue( cerr, que_forward_reads, que_forward_reads_names );
	cerr << flush;
#endif
	QUEUE_READS_NAME::iterator it;
	for (it=que_forward_reads_names.begin(); it!=que_forward_reads_names.end(); it++) {
		string & read_name = *it;
		ReadProcessed * r = que_forward_reads[read_name];
		if ( r->is_valid() ) {
			out_line++;
			if (out_line==1) r->print_header( print_level, print_tag_RG );
			r->print( print_level, print_tag_RG );
			r->methycount_bins( bins2methycount );
			int marker_of_read = r->get_marker_of_read_reside_in();
			bins2methycount[marker_of_read][3]++; // count this reverse read as a fragment in this bin
		}
	}
	// clear the queue
	que_forward_reads_names.clear();
	que_forward_reads.clear();
	if ( !(sam_file.compare("stdin")==0) ) {
		fin.close();
	}
}

void print_queue(ostream & os, HISTORY_READS & q, QUEUE_READS_NAME & q_name) {
	int i = 0;
	os << "--que_len=" << q_name.size() << endl;
	for (QUEUE_READS_NAME::iterator it=q_name.begin(); it!=q_name.end(); it++) {
		i++;
		string & read_name = *it;
		ReadProcessed * r = q[read_name];
		string strand = "+";
		if (r->is_reverse()) strand = "-";
		os << i << ".\t" << read_name << "\t" << r->get_chr() << "\t" << r->get_start_pos() << "\t" << r->get_end_pos() << "\t" << strand << "\t" << r->is_paired() << endl;
	}
	os << "--end of queue" << endl;
}

// unfinished yet
void overlap_stat_of_all_paired_reads(string & sam_file,
	Bins_end_coord & bins_end_coord, Bins_index & bins_index,
	int min_cpg_sites)
{
	cerr << "reading '" << sam_file << "'" << endl;
	istream * in=&cin; // default is stdin
	ifstream fin;
	if ( !(sam_file.compare("stdin")==0) ) {
		fin.open(sam_file.c_str());
		if (fin.fail()){
			cerr << "Error: Unable to read " << sam_file << " in overlap_stat_of_all_paired_reads()" << endl;
			exit(EXIT_FAILURE);
		}
		in = &fin;
	}
	char line[MAX_LINE_CHAR];
	unsigned long i_line=0;
	unsigned long out_line=0;
	HISTORY_READS que_forward_reads;
	QUEUE_READS_NAME que_forward_reads_names;
	while(!(*in).getline(line, MAX_LINE_CHAR).eof()) {
		//process the input line
		string line_(line);
		Sam rawread(line_);
		string & read_name = rawread.reference_id();
		bool is_paired = rawread.is_paired();
		bool is_reverse = rawread.is_reverse();
		ReadProcessed* read = new ReadProcessed(rawread, bins_end_coord, bins_index, min_cpg_sites);
		// process only paired reads
		if ( is_paired ) {
			// a paired-end (PE) read
			// find its paired read in the other strand, then get the fragment of this read pair
			// In a sorted sam file, usually the read in the forward (+) strand should occurs before the read in the reverse (-) strand.
			if ( !is_reverse ) {
				// a forward PE read
				// If it does not fall into a marker region, delete it; otherwise deposit it to the queue (without checking its valid cpg site number) and will be processed (1) when encountering its paired backward read later; and (2) when this forward read becomes the front of the queue and the queue size exceeds the limit.
				if (!read->is_within_markers()) {
					delete read;
				} else {
					que_forward_reads_names.push_back( read_name );
					que_forward_reads[read_name] = read;
					// check if the queue size exceeds the limit, if so, process, print and remove the read at the front of the queue
					if ( que_forward_reads_names.size() > NUM_HISTORY_READS_KEPT ) {
						// the read in the front of the queue indicates this is a forward read and still cannot find its paired backward read. So we need to process and output this read, then remove it from the queue to keep queue size not exceeding the limit.
						// keep the queue size <= NUM_HISTORY_READS_KEPT, by removing the read in the front of the queue
						string & forward_history_read_name = que_forward_reads_names.front();
						ReadProcessed * forward_history_read = que_forward_reads[forward_history_read_name];
						que_forward_reads.erase( forward_history_read_name );
						delete forward_history_read;
						que_forward_reads_names.pop_front();
					}
				}
			} else {
				// a reverse PE read
				// we get its matched forward PE read, then check the fragment that consists of two PE reads
				if ( que_forward_reads.find(read_name) == que_forward_reads.end() ) {
					// unable to find its matched forward PE read in the queue
					delete read;
					continue;
				} else {
					// this is a complete fragment (forward read + reverse read), we found its paired forward read in the history read queue.
					// retrieve its paired forward read in the history queue
					ReadProcessed * forward_matched_read = que_forward_reads[read_name];
					ReadPair fragment( *forward_matched_read, *read, min_cpg_sites );
					if ( fragment.is_valid() ) {
					}
					que_forward_reads.erase( read_name );
					delete forward_matched_read;
					QUEUE_READS_NAME::iterator it = std::find(que_forward_reads_names.begin(), que_forward_reads_names.end(), read_name);
					que_forward_reads_names.erase( it );
				}
			}
		}
	}
	// clear the queue
	que_forward_reads_names.clear();
	que_forward_reads.clear();
	if ( !(sam_file.compare("stdin")==0) ) {
		fin.close();
	}
}

