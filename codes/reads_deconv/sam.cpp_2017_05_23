ReadProcessed::ReadProcessed(Sam & rawread, Bins_end_coord & bins_end_coord,
	Bins_index & bins_index, int min_cpg_sites_)
{
	min_cpg_sites = min_cpg_sites_;
	within_markers = false;
	checked_valid_cpg_sites = false;
	valid = false;
	read_name = rawread.reference_id();
	chr = rawread.reference_name();
	start_pos = rawread.reference_start();
	end_pos = rawread.reference_end();
	tag_RG = rawread.get_tag("RG");
	reverse = rawread.is_reverse();
	paired = rawread.is_paired();
	//cerr << read << endl;
	int region_length_covered_by_this_bin;
	int bin_internal_index = find_overlap_bin(bins_end_coord, chr, start_pos, end_pos, region_length_covered_by_this_bin);
	if (bin_internal_index==-1) {
		// For avoiding print too many warning messages, we ignore them here
		//cerr << "Warn: " << chr << ":" << start_pos << "-" << end_pos << " doesn't exist in bin!" << endl; 
		return;
	}
	boundary = bins_end_coord[chr][bin_internal_index];
	marker1_index = bins_index[chr][bin_internal_index]; // fill in member variable
	marker2_index = -1; // -1 indicates the read completely falls into marker1, without falling into marker2. fill in member variable
	// six possible values for marker1_index, marker2_index
	//	bad:	0	0
	//	bad:	0	-1
	//	good:	0	9(non-zero)
	//	good:	9(non-zero)	0
	//	good:	9(non-zero)  -1
	//	good:	9(non-zero)  10(non-zero)
	if (region_length_covered_by_this_bin < rawread.reference_length()) {
		// this read covers two consecutive bins: "bin_internal_index" and "bin_internal_index+1".
		marker2_index = bins_index[chr][bin_internal_index+1]; // marker2_index may be 0 or non-zero
	}
	if ( marker1_index>0 || (marker2_index>0) ) {
		// 4 good cases: at least one non-zeros for marker1_index and marker2_index
		within_markers = true;
		// the read covers at least one marker, not completely falling into complementary bins
		// obtain cpg_sites and methylation_status
		rawread.parse_XM_tag_of_BISMARK_software(start_pos, reverse, cpg_sites, methylation_status); // fill in member variable: cpg_sites, methylation_status
		//cerr << marker1_index << "\t" << chr << "\t" << start_pos << "\t" << end_pos << "\t" << cpg_sites.size() << endl;
		// further check if this read has at least 'min_cpg_sites' CpG sites within the bin.
		check_valid_cpg_sites(); // fill member variables: valid_cpg_sites, valid_methylation_status
		checked_valid_cpg_sites = true;
		if (get_num_valid_cpg_sites()>=min_cpg_sites) {
			valid = true;
		}
	}
}

void ReadProcessed::methycount_bins( Bins2Values & bins2methycount )
{
	// get counts for number of methylated and unmethylated
	// bugs:
	//   (1) when get_num_valid_cpg_sites()< min_cpg_sites, we ignore these reads which may possibly have a number of valid CpG sites. However, if we use min_cpg_sites=1, then this bug is gone away.
	//   (2) when (marker1_index>0 and marker2_index>0), we count this read twice in both marker1 and marker2. In real data, this case almost never happens.
	if (marker1_index>0) {
		bins2methycount[marker1_index][0] += count(get_valid_methylation_status().begin(), get_valid_methylation_status().end(), '1');
		bins2methycount[marker1_index][1] += count(get_valid_methylation_status().begin(), get_valid_methylation_status().end(), '0');
		//if (get_num_valid_cpg_sites()>0)
		bins2methycount[marker1_index][2]++; // count the number of reads in this bin
	}
	if (marker2_index>0) {
		bins2methycount[marker2_index][0] += count(get_valid_methylation_status().begin(), get_valid_methylation_status().end(), '1');
		bins2methycount[marker2_index][1] += count(get_valid_methylation_status().begin(), get_valid_methylation_status().end(), '0');
		bins2methycount[marker2_index][2]++; // count the number of reads in this bin
		//if (get_num_valid_cpg_sites()>0)
		bins2methycount[marker2_index][2]++; // count the number of reads in this bin
	}
}

